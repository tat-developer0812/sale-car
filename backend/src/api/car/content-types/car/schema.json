{
  "kind": "collectionType",
  "collectionName": "cars",
  "info": {
    "singularName": "car",
    "pluralName": "cars",
    "displayName": "Car",
    "description": "Car listing"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "brand": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::brand.brand",
      "inversedBy": "cars"
    },
    "price": {
      "type": "biginteger",
      "required": true
    },
    "pricePromo": {
      "type": "biginteger"
    },
    "year": {
      "type": "integer",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["available", "sold", "coming-soon"],
      "default": "available"
    },
    "stockCount": {
      "type": "integer",
      "default": 0
    },
    "category": {
      "type": "enumeration",
      "enum": ["sedan", "suv", "mpv", "hatchback", "pickup"]
    },
    "fuelType": {
      "type": "enumeration",
      "enum": ["gasoline", "diesel", "hybrid", "electric"]
    },
    "transmission": {
      "type": "enumeration",
      "enum": ["manual", "automatic", "cvt"]
    },
    "shortDescription": {
      "type": "text",
      "maxLength": 300
    },
    "fullDescription": {
      "type": "richtext"
    },
    "features": {
      "type": "json"
    },
    "colors": {
      "type": "json"
    },
    "mainImage": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "video": {
      "type": "string"
    },
    "brochure": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["files"]
    },
    "specs": {
      "type": "component",
      "repeatable": false,
      "component": "car.specs"
    },
    "highlights": {
      "type": "json"
    },
    "pros": {
      "type": "json"
    },
    "cons": {
      "type": "json"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "views": {
      "type": "integer",
      "default": 0
    },
    "leadCount": {
      "type": "integer",
      "default": 0
    },
    "relatedCars": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::car.car"
    }
  }
}
