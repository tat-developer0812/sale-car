{
  "kind": "collectionType",
  "collectionName": "posts",
  "info": {
    "singularName": "post",
    "pluralName": "posts",
    "displayName": "Post",
    "description": "Blog post"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text",
      "maxLength": 300
    },
    "content": {
      "type": "richtext"
    },
    "category": {
      "type": "enumeration",
      "enum": ["review", "comparison", "guide", "news", "promotion"]
    },
    "tags": {
      "type": "json"
    },
    "featuredImage": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "relatedCars": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::car.car"
    },
    "author": {
      "type": "string",
      "default": "Admin"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "views": {
      "type": "integer",
      "default": 0
    },
    "readTime": {
      "type": "integer"
    }
  }
}
